rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'gamragb@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'staff') == 'admin')
      ); 
    }

    // --- Match Blocks ---

    match /system/ping {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if true; 
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    match /sales/{saleId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
    
    match /payments/{paymentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /charges/{chargeId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
