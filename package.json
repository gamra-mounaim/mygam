{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "start": "node dist-server/server.cjs",
    "dev": "tsx server.ts",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node16 --external:better-sqlite3 --external:express --external:cors --external:dotenv --external:googleapis --external:nodemailer --external:twilio --external:uuid --outfile=dist-server/server.cjs",
    "build": "vite build && npm run build:server",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server release",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@firebase/eslint-plugin-security-rules": "^0.0.1",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.103.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.0",
    "googleapis": "^171.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.13.1",
    "uuid": "^14.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.gamra.pos",
    "productName": "Gamra POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "electron-main.cjs",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ]
  }
}
